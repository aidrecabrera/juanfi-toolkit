{
  "name": "@svene/juanfi-api",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/juanfi-api.min.js",
  "types": "./dist/index.d.mts",
  "unpkg": "./dist/juanfi-api.min.js",
  "jsdelivr": "./dist/juanfi-api.min.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "npx tsdown && cp dist/juanfi-api.bundle.iife.js dist/juanfi-api.min.js && cp dist/juanfi-api.bundle.iife.js.map dist/juanfi-api.min.js.map && cp dist/juanfi-api.min.js dist/juanfi-api.min.js.map ../../public/js/",
    "test": "vitest run"
  }
}
